# App
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://flow:flow123@postgres:5432/cortex_flow

# JWT
JWT_SECRET=cortex-flow-secret-change-in-prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# n8n
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=

# SSO com Cortex Control (opcional)
# Deve ser o MESMO valor de JWT_SECRET do Cortex Control
CRM_SSO_SECRET=cortex-secret-key-change-in-production
CRM_BASE_URL=http://localhost:3000

# URL do Cortex Flow (usada pelo Control para redirecionar)
CORTEX_FLOW_FRONT_URL=http://localhost:3003

# Frontend
FRONTEND_URL=http://localhost:3003

# URL pública para webhooks externos
PUBLIC_WEBHOOK_BASE_URL=http://localhost:3002
